# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Ignore everything
*

# But keep the gitignore itself
!.gitignore
# dependencies
node_modules/
.pnp/
.pnp.js

# environment variables
.env
.env.*
!.env.example

# testing
coverage/

# production
build/

# misc
.DS_Store

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*